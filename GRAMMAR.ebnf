(* Property Graph Markdown 0.1 relationship-label grammar. *)

SemanticRelationshipLabel ::=
    RelationshipDescriptor ;

RelationshipDescriptor ::=
    RelationshipType PropertyMap? ;

RelationshipType ::=
    UppercaseIdentifier ;

UppercaseIdentifier ::=
    UppercaseLetter (UppercaseLetter | Digit | "_")* ;

PropertyMap ::=
    YAMLFlowMapping ;

(* PropertyMap delegates to YAML 1.2 Flow Mapping. *)
(* This grammar intentionally defines no Markdown block syntax. *)
